---
// Event Gallery Archive Component
---

<section id="event-gallery-section" class="py-24 relative overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16">
      <span class="text-[#991b1b] font-bold tracking-widest uppercase text-sm mb-4 block">Etkinlik Arşivi</span>
      <h2 class="text-3xl md:text-5xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-6">Geçmiş Etkinliklerimiz</h2>
      <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 max-w-2xl mx-auto font-light">Topluluğumuzun unutulmaz anları, fikirlerin buluştuğu özel etkinlikler.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Event 1 -->
      <div class="group relative overflow-hidden rounded-3xl border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(153,27,27,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] bg-white dark:bg-[#1e293b] transition-all duration-300 hover:shadow-[0_25px_50px_-12px_rgba(153,27,27,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)] hover:-translate-y-1">
        <div class="overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=400&h=300&fit=crop&crop=center"
            alt="Felsefe Tartışmaları"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
          />
        </div>
        <div class="p-6">
          <h3 class="text-xl text-[#1e293b] dark:text-[#e2e8f0] font-bold mb-2">Felsefe Tartışmaları</h3>
          <p class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 text-sm font-medium">15 Mart 2024</p>
        </div>
      </div>

      <!-- Event 2 -->
      <div class="group relative overflow-hidden rounded-3xl border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(153,27,27,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] bg-white dark:bg-[#1e293b] transition-all duration-300 hover:shadow-[0_25px_50px_-12px_rgba(153,27,27,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)] hover:-translate-y-1">
        <div class="overflow-hidden">
          <img
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=300&fit=crop&crop=center"
            alt="Kitap Kulübü Toplantısı"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
          />
        </div>
        <div class="p-6">
          <h3 class="text-xl text-[#1e293b] dark:text-[#e2e8f0] font-bold mb-2">Kitap Kulübü Toplantısı</h3>
          <p class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 text-sm font-medium">22 Nisan 2024</p>
        </div>
      </div>

      <!-- Event 3 -->
