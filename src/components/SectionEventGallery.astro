      <!-- Event 5 -->
      <div class="group relative overflow-hidden rounded-3xl border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(153,27,27,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] bg-white dark:bg-[#1e293b] transition-all duration-300 hover:shadow-[0_25px_50px_-12px_rgba(153,27,27,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)] hover:-translate-y-1">
        <div class="overflow-hidden">
