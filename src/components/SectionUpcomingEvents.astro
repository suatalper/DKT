---
// Upcoming Events & Workshops Section Component
---

<section id="upcoming-events-section" class="py-24 relative overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16">
      <span class="text-[#0891b2] font-bold tracking-widest uppercase text-sm mb-4 block">Yaklaşan Etkinlikler</span>
      <h2 class="text-3xl md:text-5xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-6">Etkinlikler ve Atölyeler</h2>
      <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 max-w-2xl mx-auto font-light">Gelecek dönem etkinlik takvimimizi keşfedin. Fikirlerinizi derinleştirin, yeni beceriler edinin.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Event Card 1 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#ecfeff] dark:bg-[#0891b2]/20 border border-[#0891b2]/20 mb-4">
            <span class="text-xs font-semibold text-[#0891b2]">15 Mart 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Felsefe ve Teknoloji Diyaloğu</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Dijital çağda felsefi düşüncenin yeri nedir? Teknoloji etiği ve insan doğası üzerine derinlemesine tartışma.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Kayıt Ol
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Event Card 2 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#f0fdf4] dark:bg-emerald-500/10 border border-emerald-500/20 mb-4">
            <span class="text-xs font-semibold text-emerald-600 dark:text-emerald-400">22 Nisan 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Eleştirel Düşünme Atölyesi</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Bilgi çağına uyum sağlamak için eleştirel düşünme becerilerini geliştirin. Pratik egzersizlerle öğrenin.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Detaylar
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Event Card 3 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#fdf4ff] dark:bg-fuchsia-500/10 border border-fuchsia-500/20 mb-4">
            <span class="text-xs font-semibold text-fuchsia-600 dark:text-fuchsia-400">10 Mayıs 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Yaratıcı Yazma Pratikleri</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Öykü, deneme ve makale yazımında modern teknikler. Profesyonel yazarlarla interaktif oturumlar.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Kayıt Ol
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Event Card 4 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#fff7ed] dark:bg-orange-500/10 border border-orange-500/20 mb-4">
            <span class="text-xs font-semibold text-orange-600 dark:text-orange-400">5 Haziran 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Bilim Tarihi Sohbetleri</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Bilimsel keşiflerin tarihsel bağlamı. Büyük buluşların ardındaki hikayeler ve dersler.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Detaylar
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Event Card 5 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#fff1f2] dark:bg-rose-500/10 border border-rose-500/20 mb-4">
            <span class="text-xs font-semibold text-[#991b1b] dark:text-rose-400">18 Temmuz 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Dijital Sanat ve Tasarım</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Teknoloji ve sanatın kesişim noktası. Dijital araçlarla yaratıcı ifade yöntemleri.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Kayıt Ol
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Event Card 6 -->
      <div class="group bg-white dark:bg-[#1e293b] border border-gray-100 dark:border-slate-700 rounded-3xl p-8 hover:shadow-[0_20px_40px_-15px_rgba(8,145,178,0.15)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] transition-all duration-300 hover:-translate-y-2 shadow-sm">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#eff6ff] dark:bg-blue-500/10 border border-blue-500/20 mb-4">
            <span class="text-xs font-semibold text-blue-600 dark:text-blue-400">12 Eylül 2026</span>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-3">Geleceğin Eğitimi</h3>
          <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 text-sm leading-relaxed">
            Eğitim sisteminin geleceği üzerine tartışmalar. Yapay zeka, kişiselleştirme ve yeni öğrenme modelleri.
          </p>
        </div>
        <div class="pt-6 border-t border-gray-100 dark:border-slate-800 relative">
          <a href="#" class="inline-flex items-center text-sm font-semibold text-[#0891b2] hover:text-[#0891b2]/80 transition-colors duration-200">
            Detaylar
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center mt-16">
      <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 mb-6 font-light">Daha fazla etkinlik için takipte kalın</p>
      <a href="#community-registration-section" class="inline-flex items-center px-8 py-4 bg-white dark:bg-[#1e293b] text-[#0891b2] rounded-full font-semibold transition-all shadow-[0_10px_20px_rgba(8,145,178,0.1)] hover:shadow-[0_15px_30px_rgba(8,145,178,0.2)] hover:-translate-y-1">
        Tüm Etkinlikleri Gör
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>