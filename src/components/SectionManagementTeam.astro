---
// Management Team Section Component
---

<section id="management-team-section" class="py-24 relative overflow-hidden">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center mb-16">
      <span class="text-[#0891b2] font-bold tracking-widest uppercase text-sm mb-4 block">Yönetim Kadrosu</span>
      <h2 class="text-3xl md:text-5xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-6">Düşünce ve Kitap Topluluğu Yönetim Ekibi</h2>
      <p class="text-[#1e293b]/70 dark:text-[#e2e8f0]/70 max-w-2xl mx-auto font-light">Fikirlerin önderleri, topluluğumuzun rehberleri. Her biri alanında uzman, vizyon sahibi liderlerimiz.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Team Member 1 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=AK"
                alt="Ahmet Kaya"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Ahmet Kaya</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">Genel Sekreter Yardımcısı</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Düşünce özgürlüğü, toplumun ilerlemesinin temelidir."
          </blockquote>
        </div>
      </div>

      <!-- Team Member 2 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=ED"
                alt="Elif Demir"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Elif Demir</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">Etkinlik Koordinatörü</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Her kitap, yeni bir dünya kapısıdır."
          </blockquote>
        </div>
      </div>

      <!-- Team Member 3 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=MÖ"
                alt="Mehmet Öz"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Mehmet Öz</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">İçerik Editörü</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Eleştirel düşünme, çağımızın en değerli becerisidir."
          </blockquote>
        </div>
      </div>

      <!-- Team Member 4 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=AY"
                alt="Ayşe Yıldız"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Ayşe Yıldız</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">Topluluk İlişkileri Müdürü</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Birlikte düşünmek, birlikte büyümektir."
          </blockquote>
        </div>
      </div>

      <!-- Team Member 5 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=CA"
                alt="Caner Akın"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Caner Akın</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">Teknik Koordinatör</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Teknoloji, düşünceyi sınırlandırmamalı, özgürleştirmelidir."
          </blockquote>
        </div>
      </div>

      <!-- Team Member 6 -->
      <div class="group relative bg-white dark:bg-[#1e293b] rounded-3xl overflow-hidden border border-gray-100 dark:border-slate-700 shadow-[0_20px_40px_-15px_rgba(8,145,178,0.1)] dark:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(8,145,178,0.25)] dark:hover:shadow-[0_25px_50px_-12px_rgba(0,0,0,0.6)]">
        <div class="p-8 text-center">
          <div class="relative mb-6">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden border-2 border-gray-100 dark:border-slate-700 group-hover:border-[#0891b2] transition-colors duration-300">
              <img
                src="https://via.placeholder.com/96x96/64748b/ffffff?text=ZK"
                alt="Zeynep Kara"
                class="w-full h-full object-cover grayscale sepia-[.2] group-hover:grayscale-0 group-hover:sepia-0 transition-all duration-500 transform group-hover:scale-110"
              />
            </div>
          </div>
          <h3 class="text-xl font-bold text-[#1e293b] dark:text-[#e2e8f0] mb-2">Zeynep Kara</h3>
          <p class="text-[#0891b2] text-sm mb-4 font-medium">Araştırma Asistanı</p>
          <blockquote class="text-[#1e293b]/60 dark:text-[#e2e8f0]/60 italic text-sm">
            "Bilgi, paylaşılmadıkça değerini yitirir."
          </blockquote>
        </div>
      </div>
    </div>
  </div>
</section>